#include <stdio.h>

int main()
{
    int num;

    printf("Enter Number: ");
    scanf("%d", &num);

    if(num % 5 == 0 && num % 11 == 0)
        printf("Divisible by both 5 and 11");
    else
        printf("Not Divisible");

    return 0;
}
Sample Output
