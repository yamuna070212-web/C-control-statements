#include <stdio.h>

int main()
{
    int n, sum = 0, rem;

    printf("Enter Number: ");
    scanf("%d", &n);

    while(n != 0)
    {
        rem = n % 10;
        sum += rem;
        n /= 10;
    }

    printf("Sum of Digits = %d", sum);

    return 0;
}
Sample Output
Enter Number: 1234
Sum of Digits = 10
