#include <stdio.h>

int main()
{
    int n, reverse = 0, rem;

    printf("Enter Number: ");
    scanf("%d", &n);

    while(n != 0)
    {
        rem = n % 10;
        reverse = reverse * 10 + rem;
        n /= 10;
    }

    printf("Reverse = %d", reverse);

    return 0;
}
Sample Output
Enter Number: 1234
Reverse = 4321
