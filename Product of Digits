#include <stdio.h>

int main()
{
    int n, product = 1, rem;

    printf("Enter Number: ");
    scanf("%d", &n);

    while(n != 0)
    {
        rem = n % 10;
        product *= rem;
        n /= 10;
    }

    printf("Product of Digits = %d", product);

    return 0;
}
Sample Output
Enter Number: 1234
Product of Digits = 24
